<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InfiniteWords_Win"
        mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="220"
        x:Class="InfiniteWords_Win.SelectWindow"
        Title="New Window"
        Width="360"
        Height="220"
        SystemDecorations="None"
        Icon="/Assets/flower.ico"
        PointerPressed="OnWindowPointerPressed"
        Background="#11151C">
    <Grid Margin="16">
        <Border Background="#1B2430"
                BorderBrush="#2A3647"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
                <TextBlock Grid.Row="0"
                           Text="选择单词表"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"/>

                <Button Grid.Row="0"
                        Content="{x:Static local:Const.Version}"
                        Click="OnVersionClick"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontSize="10"
                        Foreground="#566275"
                        Background="Transparent"
                        Padding="5"
                        BorderThickness="0"
                        Cursor="Hand">
                         <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Foreground" Value="#8692A6"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                         </Button.Styles>
                </Button>

                <ListBox Grid.Row="1"
                         Name="CategoryListBox"
                         Background="#16202B"
                         BorderBrush="#2A3647"
                         Foreground="#EAF2FF"
                         Padding="3">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,5"
                                    Margin="0,2"
                                    CornerRadius="6"
                                    Background="Transparent">
                                <TextBlock Text="{Binding}" FontSize="13" Foreground="#EAF2FF"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover">
                            <Setter Property="Background" Value="#233247"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="Background" Value="#355077"/>
                        </Style>
                    </ListBox.Styles>
                </ListBox>

                <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Content="退出"
                            Click="ExitButton_Click"
                            HorizontalAlignment="Stretch"
                            Padding="12,6"
                            Background="#252F3E"
                            Foreground="#D7E3F6"
                            Height="30"
                            BorderBrush="#3B4C63"/>

                    <Button Grid.Column="1"
                            Content="开始学习"
                            Click="OpenWordWindowButton_Click"
                            HorizontalAlignment="Stretch"
                            Padding="12,6"
                            Background="#2A3647"
                            Foreground="#EAF2FF"
                            Height="30"
                            BorderBrush="#3B4C63"/>
                </Grid>


            </Grid>
        </Border>
    </Grid>
</Window>
